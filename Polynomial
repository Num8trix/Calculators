<!DOCTYPE html>
<html>
<head>
  <title>Polynomial - MathForge</title>
  <link rel="stylesheet" href="styles.css">
</head>
<body>

<div id="nav"></div>

<div class="container">
  <div class="card">
    <h2>Polynomial Division (simple)</h2>

    <input id="p1" placeholder="Dividend (e.g. x^2+3x+2)">
    <input id="p2" placeholder="Divisor (e.g. x+1)">

    <button onclick="fake()">Calculate</button>

    <div class="result" id="out"></div>
  </div>
</div>

<script src="app.js"></script>
<script>document.getElementById("nav").innerHTML = nav();</script>

<script>
function fake(){
  document.getElementById("out").innerText =
  "Step 1: Align terms\nStep 2: Divide leading terms\nStep 3: Subtract\n\n(Full algebra engine can be reattached from your original code)";
}
</script>

</body>
</html>
